        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$node[\\\"Global Config\\\"].json.OWNER_PHONE}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"URGENT: New Hot Lead from {{$node[\\\"Intent Router\\\"].json.name}} (₦{{$node[\\\"Intent Router\\\"].json.budget}}). Check your email for full details.\"\n  }\n}",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$node[\"Global Config\"].json.WHATSAPP_ACCESS_TOKEN}}"
            }
          ]
        },
        "options": {}
      },
      "name": "WhatsApp Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1750,
