# ─────────────────────────────────────────────────────────
# Lumière Studio — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value before deploying.
# NEVER commit .env to version control. Only .env.example gets committed.
# If using n8n cloud, add these as environment variables in your n8n instance settings.
# ─────────────────────────────────────────────────────────

# ── APP ───────────────────────────────────────────────────
# Used in email subjects and the admin panel header
APP_NAME=Lumière Studio

# The secret URL path for the admin panel (e.g., /my-secret-admin)
# If not set, it defaults to /admin
ADMIN_PATH=

# Studio owner email — receives hot lead alerts and error notifications
OWNER_EMAIL=

# ── WEBHOOK SECURITY ──────────────────────────────────────
# Shared secret between the frontend and n8n.
# Every request from the frontend includes this value in the webhookSecret field.
# n8n checks it immediately — requests without the correct value are rejected.
# Generate with: openssl rand -hex 32
# Set the SAME value here AND in n8n → Settings → Environment Variables.
WEBHOOK_SECRET=

# ── GOOGLE AI STUDIO ──────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
# Used in n8n to call Gemini for lead scoring. Without this, the AI step fails.
GEMINI_API_KEY=

# ── SUPABASE ──────────────────────────────────────────────
# Supabase → Project Settings → API → Project URL
SUPABASE_URL=

# Supabase → Project Settings → API → service_role (secret)
# WARNING: This key bypasses Row Level Security entirely.
# Use ONLY in n8n environment variables. Never paste into any HTML file or commit to git.
SUPABASE_SERVICE_KEY=

# ── WHATSAPP BUSINESS API (META) ──────────────────────────
# Permanent Access Token from Meta for Developers
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID from WhatsApp → Getting Started
WHATSAPP_PHONE_NUMBER_ID=

# Your personal phone number to receive alerts (e.g., 234...)
# Note: Do not include the '+' prefix for the Meta API.
OWNER_PHONE=

# ── EMAIL (SMTP) ──────────────────────────────────────────
# Used by n8n to send automated replies to clients and alerts to the owner.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ── N8N WEBHOOK ───────────────────────────────────────────
# Single webhook URL for all flows — public enquiries, admin auth, reads, and writes.
# All requests use the intent field to tell n8n what to do.
# Copy the Production URL from the Webhook node in n8n after activating the workflow.
# Paste into N8N_WEBHOOK in both index.html and admin-panel.html.
N8N_WEBHOOK=
